    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import sys, os, io\r\n\r\n# --- Dynamo / Revit plumbing ---\r\nimport clr\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import (\r\n    FilteredElementCollector, BuiltInCategory, ElementCategoryFilter, LogicalOrFilter,\r\n    Element, Color, OverrideGraphicSettings, FillPatternElement, FillPatternTarget, View\r\n)\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nuidoc = DocumentManager.Instance.CurrentUIApplication.ActiveUIDocument\r\n\r\n# --- Inputs ---\r\ns_parameter = IN[0]\r\nstart0_file_pathandname = IN[1]\r\napply_in_active_view = bool(IN[2])\r\ndiameter = IN[3]\r\nduct_size_1 = IN[4]\r\nduct_size_2 = IN[5]\r\nOUT = {}\r\nOUT['s_parameter'] = s_parameter\r\n# --- Helpers ---\r\ndef get_elements_of_categories(document):\r\n    s_category = [\r\n        BuiltInCategory.OST_Walls,\r\n        BuiltInCategory.OST_Floors,\r\n        BuiltInCategory.OST_Ceilings,\r\n        BuiltInCategory.OST_Windows,\r\n        BuiltInCategory.OST_Doors\r\n    ]\r\n    s_filter = [ElementCategoryFilter(category) for category in s_category]\r\n    or_filter = LogicalOrFilter(s_filter)\r\n    column = FilteredElementCollector(document).WherePasses(or_filter).WhereElementIsNotElementType()\r\n    # stable order: sort by UniqueId\r\n    s_element = sorted(list(column), key=lambda e: e.UniqueId)\r\n    return s_element\r\n\r\ndef read_params(e, s_parameter):\r\n    s_converter = {'AtticFloor_CanBeCovered': {'No': 'FALSE', 'Sì': 'TRUE'},\r\n                    'Leaning': {'No': 'FALSE', 'Sì': 'TRUE'},\r\n                    'Bonding': {'No': 'FALSE', 'Sì': 'TRUE'},\r\n                    'Infill': {'No': 'FALSE', 'Sì': 'TRUE'},\r\n                    'Demolition': {'No': 'FALSE', 'Sì': 'TRUE'},\r\n                    'Type': {'Pavimenti': 'Surface:Floor:InnerSide',\r\n                            'Muri': 'Surface:Wall:InnerSide',\r\n                            'Controsoffitti': 'Surface:Ceiling:InnerSide',\r\n                            'Tetti': 'Surface:Roof:InnerSide',\r\n                            'Porte': 'Door/Window',\r\n                            'Finestre': 'Door/Window'}}\r\n    id = e.UniqueId\r\n    OUT[id] = {}\r\n    s_value = []\r\n    OUT[e.UniqueId]['vals'] = []\r\n    for parameter in s_parameter:\r\n        value = '?'\r\n        if parameter == 'Code':\r\n            value = id\r\n        elif parameter == 'Type':\r\n            value = e.Category.Name if e.Category else None\r\n        else:\r\n            try:\r\n                value = e.LookupParameter(parameter)\r\n                if value.StorageType == 1:\r\n                    value = value.AsInteger()\r\n                elif value.StorageType == 2:\r\n                    value = value.AsDouble()\r\n                elif value.StorageType == 3:\r\n                    value = value.AsString()\r\n                else:\r\n                    value = str(value)\r\n            except:\r\n                try:\r\n                    value = str(value)\r\n                except:\r\n                    value = \"\"\r\n            measure = '?'\r\n            try:\r\n                measure = p.Definition.GetDataType()\r\n                if measure == SpecTypeId.Length:\r\n                    value = value * 0.3048\r\n                elif measure == SpecTypeId.Area:\r\n                    value = value * 0.3048 * 0.3048\r\n                elif measure == SpecTypeId.Volume:\r\n                    value = value * 0.3048 * 0.3048 * 0.3048\r\n                elif measure == SpecTypeId.Temperature:\r\n                    value = value - 273.15\r\n                elif measure == SpecTypeId.TemperatureDifference:\r\n                    value = value\r\n                elif measure == SpecTypeId.Angle:\r\n                    value = value\r\n                elif measure == SpecTypeId.Slope:\r\n                    value = value\r\n                elif measure == SpecTypeId.Number:\r\n                    value = value\r\n            except:\r\n                pass\r\n            OUT[e.UniqueId][parameter] = measure\r\n        #OUT[id]['vals'].append(value.StorageType.Integer)\r\n        \r\n        #if parameter in list(s_converter.keys()):\r\n        #    value = s_converter[parameter][value]\r\n        s_value.append(value)\r\n    return s_value\r\n\r\ndef ensure_dir(path):\r\n    d = os.path.dirname(path)\r\n    if d and not os.path.exists(d):\r\n        os.makedirs(d)\r\n\r\ndef write_xlsx_or_csv(rows, xlsx_path, sheet):\r\n    \"\"\"\r\n    rows: list of lists (including header)\r\n    tries openpyxl; if unavailable or fails, writes CSV fallback\r\n    returns: {\"path\": written_path, \"format\": \"xlsx\"|\"csv\"}\r\n    \"\"\"\r\n    ensure_dir(xlsx_path)\r\n    # try openpyxl\r\n    try:\r\n        import openpyxl\r\n        from openpyxl import Workbook\r\n        if os.path.exists(xlsx_path):\r\n            wb = openpyxl.load_workbook(xlsx_path)\r\n            if sheet in wb.sheetnames:\r\n                ws = wb[sheet]\r\n                # clear the sheet\r\n                wb.remove(ws)\r\n                ws = wb.create_sheet(sheet)\r\n            else:\r\n                ws = wb.create_sheet(sheet)\r\n        else:\r\n            wb = Workbook()\r\n            ws = wb.active\r\n            ws.title = sheet\r\n        for r in rows:\r\n            ws.append(r)\r\n        wb.save(xlsx_path)\r\n        return {\"path\": xlsx_path, \"format\": \"xlsx\"}\r\n    except Exception as ex:\r\n        # csv fallback\r\n        csv_path = os.path.splitext(xlsx_path)[0] + \".csv\"\r\n        import csv\r\n        with io.open(csv_path, \"w\", encoding=\"utf-8\", newline=\"\") as f:\r\n            w = csv.writer(f, delimiter=';')\r\n            for r in rows:\r\n                w.writerow([u\"\" if v is None else v for v in r])\r\n        return {\"path\": csv_path, \"format\": \"csv\", \"note\": \"openpyxl non disponibile: scritto CSV\"}\r\n\r\ndef hex_to_revit_color(hexstr):\r\n    # accepts \"#RRGGBB\" or \"RRGGBB\"\r\n    s = hexstr.strip()\r\n    if s.startswith(\"#\"):\r\n        s = s[1:]\r\n    if len(s) != 6:\r\n        raise ValueError(\"Colore non valido: {}\".format(hexstr))\r\n    r = int(s[0:2], 16)\r\n    g = int(s[2:4], 16)\r\n    b = int(s[4:6], 16)\r\n    return Color(r, g, b)\r\n\r\ndef get_solid_fill_pattern_id(document):\r\n    # robust: trova il FillPatternElement con IsSolidFill True\r\n    fps = FilteredElementCollector(document).OfClass(FillPatternElement)\r\n    for fpe in fps:\r\n        try:\r\n            if fpe.GetFillPattern().IsSolidFill:\r\n                return fpe.Id\r\n        except:\r\n            pass\r\n    return None\r\n\r\ndef run_external_python(py_path):\r\n    \"\"\"\r\n    Esegue uno script Python esterno.\r\n    Preferisce usare sys.executable (CPython node); fallback a 'python'.\r\n    In IronPython usa System.Diagnostics.Process.\r\n    Ritorna (exitcode, stdout/stderr best-effort).\r\n    \"\"\"\r\n    if not py_path or not os.path.exists(py_path):\r\n        return (-1, \"Script Python non trovato: {}\".format(py_path))\r\n\r\n    try:\r\n        # Try CPython / subprocess\r\n        import subprocess\r\n        python_exec = sys.executable if sys.executable else \"python\"\r\n        proc = subprocess.Popen([python_exec, py_path],\r\n                                stdout=subprocess.PIPE,\r\n                                stderr=subprocess.PIPE,\r\n                                shell=False)\r\n        out, err = proc.communicate()\r\n        code = proc.returncode\r\n        text = (out.decode('utf-8', 'ignore') + \"\\n\" + err.decode('utf-8', 'ignore')).strip()\r\n        return (code, text)\r\n    except Exception as ex:\r\n        # IronPython fallback: System.Diagnostics.Process\r\n        try:\r\n            import System\r\n            from System.Diagnostics import Process, ProcessStartInfo\r\n            psi = ProcessStartInfo()\r\n            psi.FileName = \"python\"\r\n            psi.Arguments = '\"{}\"'.format(py_path)\r\n            psi.UseShellExecute = False\r\n            psi.RedirectStandardOutput = True\r\n            psi.RedirectStandardError = True\r\n            p = Process()\r\n            p.StartInfo = psi\r\n            p.Start()\r\n            p.WaitForExit()\r\n            out = p.StandardOutput.ReadToEnd()\r\n            err = p.StandardError.ReadToEnd()\r\n            return (p.ExitCode, (out + \"\\n\" + err))\r\n        except Exception as ex2:\r\n            return (-2, \"Impossibile eseguire lo script: {} | {}\".format(ex, ex2))\r\n\r\ndef read_output_colors(path_expected, n_expected):\r\n    \"\"\"\r\n    Ritorna lista di stringhe colore (lunghezza n_expected).\r\n    Ogni riga => es. '#AABBCC' (consentito anche senza '#').\r\n    \"\"\"\r\n    if not path_expected or not os.path.exists(path_expected):\r\n        raise IOError(\"File di output colori non trovato: {}\".format(path_expected))\r\n    s_color = []\r\n    with io.open(path_expected, 'r', encoding='utf-8') as f:\r\n        for line in f:\r\n            s = line.strip()\r\n            if s:\r\n                s_color.append(s)\r\n    if len(s_color) != n_expected:\r\n        raise ValueError(\"Numero colori ({}) diverso dal numero elementi esportati ({})\".format(len(s_color), n_expected))\r\n    return s_color\r\n# ______________________________________________\r\n# --- 1) Raccolta elementi e scrittura Excel ---\r\ns_element = get_elements_of_categories(doc)\r\ns_header = list(s_parameter)\r\ns_row = [s_header]\r\n\r\nfor e in s_element:\r\n    row = [e.UniqueId]\r\n    if s_parameter:\r\n        row += read_params(e, s_parameter)\r\n    s_row.append(row)\r\n\r\n\r\nimport json\r\nimport os\r\nstart0_file_content = '?'\r\nwith open(start0_file_pathandname, 'r') as file:\r\n    start0_file_content = json.load(file)\r\nstart_file_pathandname = os.path.normpath(os.path.join(os.path.join(start0_file_pathandname, \"..\\\\\"), start0_file_content['start_file_name']))\r\nstart_file_content = json.load(open(start_file_pathandname))\r\ninput_folder_path = start_file_content['input_folder_path']\r\ninput_folder_path = os.path.normpath(os.path.join(start_file_pathandname, input_folder_path))\r\noutput_folder_path = start_file_content['output_folder_path']\r\noutput_folder_path = os.path.normpath(os.path.join(start_file_pathandname, output_folder_path))\r\nexcel_file_pathandname = os.path.join(input_folder_path, start_file_content['input_file_name'])\r\nqueries_sheet_name = start_file_content['queries_sheet_name']\r\nelements_sheet_name = start_file_content['elements_sheet_name']\r\nexcel_info = write_xlsx_or_csv(s_row, excel_file_pathandname, elements_sheet_name)\r\npython_script_external_pathandname = os.path.normpath(os.path.join(start0_file_pathandname, \"..\\\\_CODE\\\\Intervenability_01.py\"))\r\nOUT['s_row'] = python_script_external_pathandname\r\n\r\n# --- 2) Esecuzione script esterno (opzionale, se fornito) ---\r\next_code = None\r\next_text = None\r\n\r\n#run_external_python(python_script_external_pathandname)\r\n\"\"\"\r\n# --- 3) Lettura output e applicazione colori (override in Active View) ---\r\napplied = 0\r\ns_error = []\r\nif python_script_external_pathandname:\r\n    try:\r\n        color_strings = read_output_colors(external_output_path, len(s_element))\r\n        # trova Solid Fill\r\n        solid_fill_id = get_solid_fill_pattern_id(doc)\r\n        if apply_in_active_view and solid_fill_id is not None and uidoc and uidoc.ActiveView:\r\n            v = uidoc.ActiveView\r\n            TransactionManager.Instance.EnsureInTransaction(doc)\r\n            for idx, e in enumerate(s_element):\r\n                try:\r\n                    column = hex_to_revit_color(color_strings[idx])\r\n                    ogs = OverrideGraphicSettings()\r\n                    # superfici\r\n                    ogs.SetSurfaceForegroundPatternId(solid_fill_id)\r\n                    ogs.SetSurfaceForegroundPatternColor(column)\r\n                    # linee\r\n                    ogs.SetProjectionLineColor(column)\r\n                    v.SetElementOverrides(e.Id, ogs)\r\n                    applied += 1\r\n                except Exception as ex:\r\n                    s_error.append(\"Errore colore per {}: {}\".format(e.UniqueId, ex))\r\n            TransactionManager.Instance.TransactionTaskDone()\r\n        else:\r\n            s_error.append(\"Override non applicato (Active View non disponibile o Solid Fill mancante).\")\r\n    except Exception as ex:\r\n        s_error.append(\"Lettura/applicazione colori fallita: {}\".format(ex))\r\n\r\n# --- Output report ---\r\nOUT['More'] = {\r\n    \"elements_exported\": len(s_element),\r\n    \"excel_written\": excel_info,\r\n    \"external_script\": {\"exit_code\": ext_code, \"output\": ext_text} if python_script_external_pathandname else None,\r\n    \"colors_applied\": applied,\r\n    \"errors\": s_error\r\n}\r\n\"\"\"\r\ndebug_dynamo_file_pathandname = os.path.join(output_folder_path, 'debug_dynamo.json')\r\nwith open(debug_dynamo_file_pathandname, 'w') as file:\r\n    json.dump(OUT, file)\r\n\r\npass",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
