  "Nodes": [
    {
      "ConcreteType": "CoreNodeModels.Input.StringInput, CoreNodeModels",
      "Id": "29f5cf4035a04ebda440e8a0db489600",
      "NodeType": "StringInputNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "d394451b87294080a124400de2aa6427",
          "Name": "",
          "Description": "String",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Crea una stringa.",
      "InputValue": "C:\\PATH\\TO\\hbim-intervenability-workflows\\START.json"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import sys, os, json, re, subprocess\r\n\r\n# --- Dynamo / Revit plumbing ---\r\nimport clr\r\n\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import (\r\n    SpecTypeId,\r\n    FilteredElementCollector,\r\n    BuiltInCategory,\r\n    ElementCategoryFilter,\r\n    LogicalOrFilter,\r\n    Color,\r\n    OverrideGraphicSettings,\r\n    FillPatternElement,\r\n)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nuidoc = DocumentManager.Instance.CurrentUIApplication.ActiveUIDocument\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# INPUTS FROM DYNAMO\r\n# ---------------------------------------------------------------------------\r\n\r\n# IN[0] = list of Revit parameters to export\r\n# IN[1] = path to START.json\r\n# IN[2] = apply colours in active view, True/False\r\n# IN[3] = optional path to external Python executable\r\n# IN[4] = optional path to external Python script\r\n# IN[5] = trigger / unused\r\n\r\ns_parameter = IN[0]\r\nstart0_file_pathandname = IN[1]\r\napply_in_active_view = bool(IN[2])\r\n\r\npython_exe_input = IN[3] if len(IN) > 3 else None\r\nexternal_script_input = IN[4] if len(IN) > 4 else None\r\n_ = IN[5] if len(IN) > 5 else None\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# PATH HELPERS\r\n# ---------------------------------------------------------------------------\r\n\r\ndef norm(path):\r\n    return os.path.normpath(str(path))\r\n\r\n\r\ndef is_empty(value):\r\n    if value is None:\r\n        return True\r\n    if str(value).strip() in [\"\", \"?\", \"None\", \"null\"]:\r\n        return True\r\n    return False\r\n\r\n\r\ndef must_exist(path, label):\r\n    if not path or not os.path.exists(path):\r\n        raise Exception(\"{} not found: {}\".format(label, path))\r\n\r\n\r\ndef ensure_parent_dir(path):\r\n    directory = os.path.dirname(path)\r\n    if directory and not os.path.exists(directory):\r\n        os.makedirs(directory)\r\n\r\n\r\nmust_exist(start0_file_pathandname, \"START.json\")\r\n\r\nBASE_DIR = norm(os.path.dirname(start0_file_pathandname))\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# READ CONFIGURATION FILES\r\n# ---------------------------------------------------------------------------\r\n\r\nwith open(start0_file_pathandname, \"r\", encoding=\"utf-8\") as file:\r\n    start0 = json.load(file)\r\n\r\nstart_file_name = start0.get(\"start_file_name\", \"START - AdD - Dynamo.json\")\r\nstart_file_pathandname = norm(os.path.join(BASE_DIR, start_file_name))\r\n\r\nmust_exist(start_file_pathandname, \"START - AdD - Dynamo.json\")\r\n\r\nwith open(start_file_pathandname, \"r\", encoding=\"utf-8\") as file:\r\n    cfg = json.load(file)\r\n\r\ninput_file_name = cfg.get(\"input_file_name\", \"InputDataLFO.xlsx\")\r\nelements_sheet_name = cfg.get(\"elements_sheet_name\", \"ELEMENTS_Dynamo\")\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# LOCAL WORKFLOW FOLDERS\r\n# ---------------------------------------------------------------------------\r\n\r\n# The repository structure is expected to be:\r\n#\r\n# hbim-intervenability-workflows/\r\n# ├── START.json\r\n# ├── START - AdD - Dynamo.json\r\n# ├── python/\r\n# │   └── Intervenability_01-LFO.py\r\n# ├── dynamo/\r\n# │   └── Intervenability_02-LFO.dyn\r\n# └── AdD_Dynamo/\r\n#     ├── IN/\r\n#     │   └── InputDataLFO.xlsx\r\n#     └── OUT/\r\n#         └── Intervenability_RESULTS.xlsx\r\n\r\nIN_DIR = norm(os.path.join(BASE_DIR, \"AdD_Dynamo\", \"IN\"))\r\nOUT_DIR = norm(os.path.join(BASE_DIR, \"AdD_Dynamo\", \"OUT\"))\r\n\r\nINPUT_XLSX = norm(os.path.join(IN_DIR, input_file_name))\r\nRESULTS_XLSX_DEFAULT = norm(os.path.join(OUT_DIR, \"Intervenability_RESULTS.xlsx\"))\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# EXTERNAL SCRIPT AND PYTHON EXECUTABLE\r\n# ---------------------------------------------------------------------------\r\n\r\nif not is_empty(external_script_input):\r\n    external_script_path = norm(external_script_input)\r\nelse:\r\n    external_script_path = norm(\r\n        os.path.join(BASE_DIR, \"python\", \"Intervenability_01-LFO.py\")\r\n    )\r\n\r\nmust_exist(external_script_path, \"Intervenability_01-LFO.py\")\r\n\r\nif not is_empty(python_exe_input):\r\n    PYTHON_EXE = norm(python_exe_input)\r\nelse:\r\n    # Fallback: use the Python executable available to the current environment.\r\n    # In many Revit/Dynamo setups, users may need to pass their external Python\r\n    # executable explicitly through IN[3].\r\n    PYTHON_EXE = sys.executable\r\n\r\nmust_exist(PYTHON_EXE, \"Python executable\")\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# REVIT HELPERS\r\n# ---------------------------------------------------------------------------\r\n\r\ndef get_elements_of_categories(document):\r\n    categories = [\r\n        BuiltInCategory.OST_Walls,\r\n        BuiltInCategory.OST_Floors,\r\n        BuiltInCategory.OST_Ceilings,\r\n        BuiltInCategory.OST_Windows,\r\n        BuiltInCategory.OST_Doors,\r\n    ]\r\n\r\n    filters = [ElementCategoryFilter(category) for category in categories]\r\n    or_filter = LogicalOrFilter(filters)\r\n\r\n    collector = (\r\n        FilteredElementCollector(document)\r\n        .WherePasses(or_filter)\r\n        .WhereElementIsNotElementType()\r\n    )\r\n\r\n    return sorted(list(collector), key=lambda element: element.UniqueId)\r\n\r\n\r\ndef get_solid_fill_pattern_id(document):\r\n    fill_patterns = FilteredElementCollector(document).OfClass(FillPatternElement)\r\n\r\n    for fill_pattern_element in fill_patterns:\r\n        try:\r\n            if fill_pattern_element.GetFillPattern().IsSolidFill:\r\n                return fill_pattern_element.Id\r\n        except Exception:\r\n            pass\r\n\r\n    return None\r\n\r\n\r\ndef hex_to_revit_color(hex_string):\r\n    value = str(hex_string).strip()\r\n\r\n    if value.startswith(\"#\"):\r\n        value = value[1:]\r\n\r\n    if len(value) != 6:\r\n        raise ValueError(\"Invalid colour value: {}\".format(hex_string))\r\n\r\n    red = int(value[0:2], 16)\r\n    green = int(value[2:4], 16)\r\n    blue = int(value[4:6], 16)\r\n\r\n    return Color(red, green, blue)\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# PARAMETER READING\r\n# ---------------------------------------------------------------------------\r\n\r\ndef read_params(element, parameter_names):\r\n    element_unique_id = element.UniqueId\r\n    values = []\r\n\r\n    for parameter_name in parameter_names:\r\n        value = \"?\"\r\n\r\n        if parameter_name == \"Code\":\r\n            value = element_unique_id\r\n\r\n        elif parameter_name == \"Type\":\r\n            value = element.Category.Name if element.Category else None\r\n\r\n        else:\r\n            try:\r\n                parameter = element.LookupParameter(parameter_name)\r\n\r\n                if parameter is None:\r\n                    value = None\r\n\r\n                else:\r\n                    if parameter.StorageType == 1:\r\n                        value = parameter.AsInteger()\r\n                    elif parameter.StorageType == 2:\r\n                        value = parameter.AsDouble()\r\n                    elif parameter.StorageType == 3:\r\n                        value = parameter.AsString()\r\n                    else:\r\n                        value = str(parameter)\r\n\r\n                    # Unit conversion where applicable.\r\n                    try:\r\n                        measure = parameter.Definition.GetDataType()\r\n\r\n                        if measure == SpecTypeId.Length:\r\n                            value = value * 0.3048\r\n                        elif measure == SpecTypeId.Area:\r\n                            value = value * 0.3048 * 0.3048\r\n                        elif measure == SpecTypeId.Volume:\r\n                            value = value * 0.3048 * 0.3048 * 0.3048\r\n                        elif measure == SpecTypeId.Temperature:\r\n                            value = value - 273.15\r\n                        elif measure == SpecTypeId.TemperatureDifference:\r\n                            value = value\r\n                        elif measure == SpecTypeId.Angle:\r\n                            value = value\r\n                        elif measure == SpecTypeId.Slope:\r\n                            value = value\r\n                        elif measure == SpecTypeId.Number:\r\n                            value = value\r\n                    except Exception:\r\n                        pass\r\n\r\n            except Exception:\r\n                try:\r\n                    value = str(value)\r\n                except Exception:\r\n                    value = \"\"\r\n\r\n        values.append(value)\r\n\r\n    return values\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# 1. EXPORT REVIT ELEMENTS TO INPUT EXCEL FILE\r\n# ---------------------------------------------------------------------------\r\n\r\nelements = get_elements_of_categories(doc)\r\n\r\nrows = [list(s_parameter)]\r\n\r\nfor element in elements:\r\n    rows.append(read_params(element, s_parameter))\r\n\r\nensure_parent_dir(INPUT_XLSX)\r\n\r\nimport openpyxl\r\nfrom openpyxl import Workbook\r\n\r\nif os.path.exists(INPUT_XLSX):\r\n    workbook = openpyxl.load_workbook(INPUT_XLSX)\r\n\r\n    if elements_sheet_name in workbook.sheetnames:\r\n        old_sheet = workbook[elements_sheet_name]\r\n        workbook.remove(old_sheet)\r\n\r\nelse:\r\n    workbook = Workbook()\r\n\r\n    try:\r\n        workbook.remove(workbook.active)\r\n    except Exception:\r\n        pass\r\n\r\nworksheet = workbook.create_sheet(elements_sheet_name)\r\n\r\nfor row in rows:\r\n    worksheet.append(row)\r\n\r\nworkbook.save(INPUT_XLSX)\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# 2. RUN EXTERNAL PYTHON SCRIPT\r\n# ---------------------------------------------------------------------------\r\n\r\nexternal_exit_code = None\r\nexternal_stdout = \"\"\r\nexternal_stderr = \"\"\r\n\r\ntry:\r\n    process = subprocess.Popen(\r\n        [PYTHON_EXE, external_script_path],\r\n        stdout=subprocess.PIPE,\r\n        stderr=subprocess.PIPE,\r\n        shell=False,\r\n    )\r\n\r\n    stdout_bytes, stderr_bytes = process.communicate()\r\n\r\n    external_exit_code = process.returncode\r\n    external_stdout = stdout_bytes.decode(\"utf-8\", \"ignore\")\r\n    external_stderr = stderr_bytes.decode(\"utf-8\", \"ignore\")\r\n\r\nexcept Exception as error:\r\n    external_exit_code = -2\r\n    external_stderr = \"Subprocess error: {}\".format(error)\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# 3. FIND RESULTS FILE\r\n# ---------------------------------------------------------------------------\r\n\r\nresults_candidates = [\r\n    RESULTS_XLSX_DEFAULT,\r\n    norm(os.path.join(IN_DIR, \"Intervenability_RESULTS.xlsx\")),\r\n]\r\n\r\n# Try to read the exact path from stdout if the external script printed it.\r\nmatch = re.search(\r\n    r\"Salvato Excel risultati:\\s*(.+Intervenability_RESULTS\\.xlsx)\",\r\n    external_stdout,\r\n)\r\n\r\nif match:\r\n    candidate = norm(match.group(1).strip())\r\n\r\n    allowed_root = norm(os.path.join(BASE_DIR, \"AdD_Dynamo\"))\r\n\r\n    if candidate.startswith(allowed_root):\r\n        results_candidates.insert(0, candidate)\r\n\r\n# Remove duplicates while preserving order.\r\nseen = set()\r\nunique_results_candidates = []\r\n\r\nfor candidate in results_candidates:\r\n    if candidate not in seen:\r\n        seen.add(candidate)\r\n        unique_results_candidates.append(candidate)\r\n\r\nresults_candidates = unique_results_candidates\r\n\r\nresults_found_path = None\r\n\r\nfor candidate in results_candidates:\r\n    if os.path.exists(candidate):\r\n        results_found_path = candidate\r\n        break\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# 4. APPLY COLOURS TO ACTIVE REVIT VIEW\r\n# ---------------------------------------------------------------------------\r\n\r\napplied = 0\r\nerrors = []\r\n\r\nif apply_in_active_view:\r\n    if results_found_path is None:\r\n        errors.append(\r\n            \"Results not found. Checked paths: {}\".format(results_candidates)\r\n        )\r\n\r\n    else:\r\n        try:\r\n            results_workbook = openpyxl.load_workbook(\r\n                results_found_path,\r\n                data_only=True,\r\n            )\r\n\r\n            if \"SUMMARY\" not in results_workbook.sheetnames:\r\n                raise Exception(\r\n                    \"Sheet 'SUMMARY' not found in {}\".format(results_found_path)\r\n                )\r\n\r\n            summary_sheet = results_workbook[\"SUMMARY\"]\r\n\r\n            header = [\r\n                str(cell.value).strip() if cell.value is not None else \"\"\r\n                for cell in summary_sheet[1]\r\n            ]\r\n\r\n            def column_index(name):\r\n                return header.index(name) if name in header else None\r\n\r\n            index_code = column_index(\"Code\")\r\n            index_r = column_index(\"R\")\r\n            index_g = column_index(\"G\")\r\n            index_b = column_index(\"B\")\r\n            index_hex = column_index(\"ColourHex\")\r\n\r\n            if index_code is None:\r\n                raise Exception(\"Column 'Code' is missing in SUMMARY.\")\r\n\r\n            color_map = {}\r\n\r\n            for row in summary_sheet.iter_rows(min_row=2, values_only=True):\r\n                if not row:\r\n                    continue\r\n\r\n                code = row[index_code]\r\n\r\n                if code is None:\r\n                    continue\r\n\r\n                code = str(code).strip()\r\n\r\n                # Prefer RGB columns.\r\n                if (\r\n                    index_r is not None\r\n                    and index_g is not None\r\n                    and index_b is not None\r\n                    and row[index_r] is not None\r\n                ):\r\n                    try:\r\n                        red = int(float(row[index_r]))\r\n                        green = int(float(row[index_g]))\r\n                        blue = int(float(row[index_b]))\r\n\r\n                        red = max(0, min(255, red))\r\n                        green = max(0, min(255, green))\r\n                        blue = max(0, min(255, blue))\r\n\r\n                        color_map[code] = (red, green, blue)\r\n                        continue\r\n\r\n                    except Exception:\r\n                        pass\r\n\r\n                # Fallback to HEX colour.\r\n                if index_hex is not None and row[index_hex]:\r\n                    try:\r\n                        revit_colour = hex_to_revit_color(row[index_hex])\r\n                        color_map[code] = (\r\n                            revit_colour.Red,\r\n                            revit_colour.Green,\r\n                            revit_colour.Blue,\r\n                        )\r\n                    except Exception:\r\n                        pass\r\n\r\n            solid_fill_id = get_solid_fill_pattern_id(doc)\r\n\r\n            if solid_fill_id is None:\r\n                raise Exception(\"Solid Fill pattern not found.\")\r\n\r\n            active_view = uidoc.ActiveView if uidoc else None\r\n\r\n            if active_view is None:\r\n                raise Exception(\"Active view not available.\")\r\n\r\n            TransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n            for element in elements:\r\n                unique_id = element.UniqueId\r\n\r\n                if unique_id not in color_map:\r\n                    continue\r\n\r\n                red, green, blue = color_map[unique_id]\r\n                revit_colour = Color(red, green, blue)\r\n\r\n                overrides = OverrideGraphicSettings()\r\n                overrides.SetSurfaceForegroundPatternId(solid_fill_id)\r\n                overrides.SetSurfaceForegroundPatternColor(revit_colour)\r\n                overrides.SetProjectionLineColor(revit_colour)\r\n\r\n                active_view.SetElementOverrides(element.Id, overrides)\r\n                applied += 1\r\n\r\n            TransactionManager.Instance.TransactionTaskDone()\r\n\r\n        except Exception as error:\r\n            errors.append(\"Colour application failed: {}\".format(error))\r\n\r\nelse:\r\n    errors.append(\"apply_in_active_view = False\")\r\n\r\n\r\n# ---------------------------------------------------------------------------\r\n# OUTPUT TO DYNAMO\r\n# ---------------------------------------------------------------------------\r\n\r\nOUT = {\r\n    \"BASE_DIR\": BASE_DIR,\r\n    \"IN_DIR\": IN_DIR,\r\n    \"OUT_DIR\": OUT_DIR,\r\n    \"input_written\": INPUT_XLSX,\r\n    \"elements_exported\": len(elements),\r\n    \"external_script\": external_script_path,\r\n    \"python_exe\": PYTHON_EXE,\r\n    \"external_exit_code\": external_exit_code,\r\n    \"external_stdout\": external_stdout,\r\n    \"external_stderr\": external_stderr,\r\n    \"results_candidates\": results_candidates,\r\n    \"results_found_path\": results_found_path,\r\n    \"apply_in_active_view\": apply_in_active_view,\r\n    \"colors_applied\": applied,\r\n    \"errors\": errors,\r\n}",
      "Engine": "CPython3",
